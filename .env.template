# ── Sentinel: local self-hosted Cognee + Ollama (100% on-laptop, no Cloud, no API key) ──
# Setup:
#   cp .env.template .env
#   ollama serve                     # start the local LLM runtime
#   ollama pull llama3.2             # reasoning LLM
#   ollama pull nomic-embed-text     # embeddings
#
# Nothing in here is a secret — there are no external services. Everything runs locally.

# Local single-user mode: disable multi-tenant auth (must be read before cognee imports).
ENABLE_BACKEND_ACCESS_CONTROL=false
TELEMETRY_DISABLED=1
# Disable session-memory cache so `forget` is immediately reflected in recall.
CACHING=false

# ── LLM: local Ollama (the reasoning brain) ──
# qwen2.5:3b: good at the structured JSON extraction cognify needs and fits in
# 8GB RAM. (qwen2.5:7b is more reliable but too heavy for an 8GB Air; llama3.2
# 3B is flaky on the KnowledgeGraph schema.)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
# Native structured-output: forces a valid JSON instance (small models otherwise
# echo the schema and cognify fails). Required for reliable local extraction.
LLM_INSTRUCTOR_MODE=json_schema_mode
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

# ── Embeddings: local Ollama ──
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
