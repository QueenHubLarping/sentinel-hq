# ── Sentinel: self-hosted Cognee + Groq reasoning + local Ollama embeddings ──
# Setup:
#   cp .env.template .env
#   add your Groq API key below
#   ollama serve                     # start the local embedding runtime
#   ollama pull nomic-embed-text     # embeddings

# Local single-user mode: disable multi-tenant auth (must be read before cognee imports).
ENABLE_BACKEND_ACCESS_CONTROL=false
TELEMETRY_DISABLED=1
# Disable session-memory cache so `forget` is immediately reflected in recall.
CACHING=false
# Pin the graph store: the improve() 👎-feedback loop needs Ladybug's node/edge
# feedback-weight adapter (Kuzu's lacks it). Ladybug is the 1.2.2 default; pin it anyway.
GRAPH_DATABASE_PROVIDER=ladybug

# ── LLM: Groq (the reasoning brain) ──
# Cognee uses LiteLLM, so Groq models require the groq/ prefix and no endpoint.
LLM_PROVIDER=custom
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=your-groq-api-key

# ── Embeddings: local Ollama ──
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
